# =============================================================================
# Supabase (required for discovery and test script)
# =============================================================================
# Project URL: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (secret): Project Settings → API → service_role (Reveal)
# Use only server-side; never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# Apify (optional for v1; required for live discovery later)
# =============================================================================
APIFY_API_TOKEN=your_apify_token_here

# Optional: use a specific Eventbrite actor
# APIFY_EVENTBRITE_ACTOR_ID=username/eventbrite-scraper

# =============================================================================
# Optional
# =============================================================================
# Require X-API-Key header on POST/GET /api/discovery/run
# DISCOVERY_API_KEY=your-secret
